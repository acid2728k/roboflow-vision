# ---------- Frontend (Vite) ----------
# "mock" (no keys), "proxy" (recommended), or "hosted"
VITE_API_MODE=mock

# Hosted mode only (exposed to browser bundle)
# TODO: set real hosted endpoints if using frontend-only mode.
VITE_RF_DETECT_URL=https://YOUR_ROBOFLOW_DETECT_ENDPOINT
VITE_RF_API_KEY=
VITE_SMOLVLM_URL=https://YOUR_SMOLVLM_ENDPOINT
VITE_SMOLVLM_API_KEY=

# ---------- Backend proxy ----------
BACKEND_PORT=8787

# TODO: set your secure server-side endpoints/keys (not exposed to browser)
RF_DETECT_URL=https://YOUR_ROBOFLOW_DETECT_ENDPOINT
RF_API_KEY=YOUR_SERVER_SIDE_RF_KEY
SMOLVLM_URL=https://YOUR_SMOLVLM_ENDPOINT
SMOLVLM_API_KEY=YOUR_SERVER_SIDE_SMOLVLM_KEY
